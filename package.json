{
  "name": "beatdown",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "generate:icons": "./scripts/generate-icons.sh",
    "build:css": "bun scripts/build-css.ts",
    "dev": "bun run build:css && node node_modules/.bin/electrobun dev",
    "dev:css": "bun scripts/build-css.ts --watch",
    "build": "bun run build:css && node node_modules/.bin/electrobun build --env=stable",
    "build:mac": "bun run build:css && node node_modules/.bin/electrobun build --env=stable",
    "build:linux": "bun run build:css && node node_modules/.bin/electrobun build --env=stable",
    "install:app": "bash scripts/install.sh",
    "dev:legacy": "concurrently -n server,client -c cyan,magenta \"npm run dev --workspace=server\" \"npm run dev --workspace=client\""
  },
  "workspaces": [
    "server",
    "client"
  ],
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "audiomotion-analyzer": "^4.5.4",
    "axios": "^1.6.0",
    "butterchurn": "3.0.0-beta.5",
    "butterchurn-presets": "3.0.0-beta.4",
    "cheerio": "^1.0.0-rc.12",
    "effector": "^23.0.0",
    "effector-react": "^23.0.0",
    "electrobun": "^1.16.0",
    "env-paths": "^4.0.0",
    "lucide-react": "^0.344.0",
    "milkdrop-preset-converter": "^0.1.2",
    "postcss": "^8.5.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.2.2",
    "uuid": "^9.0.0",
    "wavesurfer.js": "^7.12.4"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.183.1",
    "@types/uuid": "^9.0.0",
    "concurrently": "^8.2.0",
    "typescript": "^5.3.0"
  }
}
