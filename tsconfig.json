{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "electrobun/bun": ["./node_modules/electrobun/dist/api/bun/index.ts"],
      "electrobun/view": ["./node_modules/electrobun/dist/api/browser/index.ts"]
    }
  },
  "include": ["src/**/*", "electrobun.config.ts"]
}
